const ID = "com.zombie.fractions.v2";
let currentRole = "PLAYER";

OBR.onReady(async () => {
  currentRole = await OBR.player.getRole();
  if (currentRole === "GM") {
    document.getElementById("tab-gm").style.display = "block";
  }

  setupTabs();
  await loadPlayersList(); // Подгружаем реальных игроков в форму

  // Следим за изменениями в комнате
  OBR.room.onMetadataChange((metadata) => {
    const data = metadata[ID] || { list: [] };
    checkNewFactionNotifications(data.list);
    renderFractions(data.list);
  });

  // Первая загрузка данных
  const initialMetadata = await OBR.room.getMetadata();
  const initialData = initialMetadata[ID] || { list: [] };
  // Запоминаем текущий состав, чтобы не спамить старыми уведомлениями
  localStorage.setItem('old_fractions', JSON.stringify(initialData.list));
  renderFractions(initialData.list);

  // Кнопка Сохранить (И для Создания, и для Редактирования)
  document.getElementById("save-fac-btn").addEventListener("click", handleSaveFaction);
  document.getElementById("cancel-edit-btn").addEventListener("click", resetForm);
});

// Загрузка живых игроков из Owlbear Rodeo в выпадающий список
async function loadPlayersList() {
  const select = document.getElementById("fac-players");
  if (!select) return;
  select.innerHTML = "";

  const ownName = await OBR.player.getName();
  const roomPlayers = await OBR.party.getPlayers();

  // Добавляем себя
  const optSelf = document.createElement("option");
  optSelf.value = ownName;
  optSelf.textContent = ownName + " (Вы)";
  select.appendChild(optSelf);

  // Добавляем остальных участников за столом
  roomPlayers.forEach(p => {
    const opt = document.createElement("option");
    opt.value = p.name;
    opt.textContent = p.name;
    select.appendChild(opt);
  });
}

// Рендеринг фракций на экран
function renderFractions(list) {
  const listContainer = document.getElementById("fractions-list");
  if (!listContainer) return;
  listContainer.innerHTML = "";

  if (list.length === 0) {
    listContainer.innerHTML = '<p class="empty-msg">Секретные архивы пусты. Все фракции уничтожены...</p>';
    return;
  }

  list.forEach(fac => {
    const card = document.createElement("div");
    card.className = "fraction-card";
    card.style.borderLeft = 6px solid ${fac.color || '#8b0000'};
    
    const playersText = fac.players && fac.players.length > 0 
      ? 👥 Состав: ${fac.players.join(", ")} 
      : "👥 Состав: пустует";

    card.innerHTML = 
      <div class="fraction-header">
        <span class="fraction-icon">${fac.icon || '👥'}</span>
        <div>
          <h4 class="fraction-title">${fac.name}</h4>
          <div style="font-size:12px; color: ${fac.color}">Фракция</div>
        </div>
        <span class="fraction-count">Людей: ${fac.count || 0}</span>
      </div>
      <div class="fraction-players">${playersText}</div>
    ;

    // Если смотрит ГМ — добавляем кнопки Редактировать и Удалить (как в макете)
    if (currentRole === "GM") {
      const actions = document.createElement("div");
      actions.className = "gm-actions";
      
      const editBtn = document.createElement("button");
      editBtn.className = "edit-btn";
      editBtn.textContent = "Редактировать";
      editBtn.onclick = () => startEdit(fac);

      const deleteBtn = document.createElement("button");
      deleteBtn.className = "delete-btn";
      deleteBtn.textContent = "Удалить";
      deleteBtn.onclick = () => deleteFaction(fac.id);

      actions.appendChild(editBtn);
      actions.appendChild(deleteBtn);
      card.appendChild(actions);
    }

    listContainer.appendChild(card);
  });
}

