// Логика Создания / Редактирования фракции
async function handleSaveFaction() {
  const id = document.getElementById("fac-id").value;
  const name = document.getElementById("fac-name").value.trim();
  const icon = document.getElementById("fac-icon").value.trim() || "👥";
  const color = document.getElementById("fac-color").value;
  const count = document.getElementById("fac-count").value.trim() || "0";
  
  // Собираем массив выбранных игроков из селекта
  const select = document.getElementById("fac-players");
  const selectedPlayers = Array.from(select.selectedOptions).map(opt => opt.value);

  if (!name) return alert("Пожалуйста, введите название фракции!");

  const currentMetadata = await OBR.room.getMetadata();
  const currentData = currentMetadata[ID] || { list: [] };

  if (id) {
    // Редактируем существующую
    const index = currentData.list.findIndex(f => f.id === id);
    if (index !== -1) {
      currentData.list[index] = { id, name, icon, color, count, players: selectedPlayers };
    }
  } else {
    // Создаем новую
    const newFaction = { id: Date.now().toString(), name, icon, color, count, players: selectedPlayers };
    currentData.list.push(newFaction);
  }

  await OBR.room.setMetadata({ [ID]: currentData });
  resetForm();
  
  // Возвращаем ГМ на вкладку "Все фракции" после сохранения
  document.getElementById("tab-players").click();
}

// Заполнение формы данными для редактирования
function startEdit(fac) {
  document.getElementById("tab-gm").click(); // Переключаем вкладку на форму
  document.getElementById("gm-form-title").textContent = "Редактировать фракцию:";
  document.getElementById("fac-id").value = fac.id;
  document.getElementById("fac-name").value = fac.name;
  document.getElementById("fac-icon").value = fac.icon;
  document.getElementById("fac-color").value = fac.color || "#8b0000";
  document.getElementById("fac-count").value = fac.count;
  document.getElementById("cancel-edit-btn").style.display = "block";

  // Восстанавливаем выбранных игроков в селекте
  const select = document.getElementById("fac-players");
  Array.from(select.options).forEach(opt => {
    opt.selected = fac.players ? fac.players.includes(opt.value) : false;
  });
}

// Сброс формы в стандартное состояние
function resetForm() {
  document.getElementById("gm-form-title").textContent = "Добавить фракцию:";
  document.getElementById("fac-id").value = "";
  document.getElementById("fac-name").value = "";
  document.getElementById("fac-icon").value = "";
  document.getElementById("fac-color").value = "#8b0000";
  document.getElementById("fac-count").value = "";
  document.getElementById("cancel-edit-btn").style.display = "none";
  
  const select = document.getElementById("fac-players");
  Array.from(select.options).forEach(opt => opt.selected = false);
}

// Удаление фракции
async function deleteFaction(id) {
  if (!confirm("Вы уверены, что хотите уничтожить эту фракцию?")) return;
  const currentMetadata = await OBR.room.getMetadata();
  const currentData = currentMetadata[ID] || { list: [] };
  currentData.list = currentData.list.filter(f => f.id !== id);
  await OBR.room.setMetadata({ [ID]: currentData });
}

